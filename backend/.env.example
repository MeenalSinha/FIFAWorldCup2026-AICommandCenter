# --- Application ---
ENVIRONMENT=development
APP_NAME="FIFA World Cup 2026 AI Command Center"
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000

# --- Auth ---
JWT_SECRET_KEY=change-me-in-secret-manager
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Demo mode ---
# When true (or when no GCP credentials are present) all AI/Google services
# fall back to deterministic, realistic mock responses so the platform
# runs fully offline for judges/demos.
DEMO_MODE=true

# --- Google Cloud / Gemini (leave blank to stay in demo mode) ---
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_MAPS_API_KEY=
FIREBASE_PROJECT_ID=
BIGQUERY_DATASET=stadium_intelligence
PUBSUB_TOPIC_INCIDENTS=incident-events
